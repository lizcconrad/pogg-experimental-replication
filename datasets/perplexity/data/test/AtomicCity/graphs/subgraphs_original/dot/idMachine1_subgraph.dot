strict digraph {
idMachine1 [node_type="entity_node", root=root, lexicon_key=idMachine];
idOnSwitch1 [lexicon_key=idOnSwitch];
yes [lexicon_key=yes];
off [lexicon_key=off];
idElevatorOpening [lexicon_key=idElevatorOpening];
idMachine1 -> idOnSwitch1 [label="idMachine1_prop_idPowerControl", edge_type=property, lexicon_key=idPowerControl];
idMachine1 -> yes [label="idMachine1_prop_idImmovable", edge_type=property, lexicon_key=idImmovable];
idMachine1 -> off [label="idMachine1_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
idMachine1 -> idElevatorOpening [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
}
