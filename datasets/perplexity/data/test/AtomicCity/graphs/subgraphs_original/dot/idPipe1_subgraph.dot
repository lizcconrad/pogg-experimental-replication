strict digraph {
idPipe1 [node_type="entity_node", root=root, lexicon_key=idPipe];
idElevator1 [lexicon_key=idElevator];
idButton1 [lexicon_key=idButton];
idShutoff [lexicon_key=idShutoff];
idPipe1 -> idElevator1 [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
idElevator1 -> idButton1 [label="idElevator1_prop_idCurrentLevel", edge_type=property, lexicon_key=idCurrentLevel];
idElevator1 -> idShutoff [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
}
