strict digraph {
idCabin1 [node_type="entity_node", root=root, lexicon_key=idCabin];
idChip1 [lexicon_key=idChip];
idpotato [lexicon_key=idpotato];
salty [lexicon_key=salty];
idPill1 [lexicon_key=idPill];
idCabin1 -> idChip1 [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
idChip1 -> idpotato [label="idChip1_prop_idMaterial", edge_type=property, lexicon_key=idMaterial];
idChip1 -> salty [label="idChip1_prop_idSaltiness", edge_type=property, lexicon_key=idSaltiness];
idChip1 -> idPill1 [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
}
