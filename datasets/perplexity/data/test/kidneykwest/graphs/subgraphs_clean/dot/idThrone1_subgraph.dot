strict digraph {
idThrone1 [lexicon_key=idThrone];
yes [lexicon_key=yes];
idiron [lexicon_key=idiron];
idChip2 [lexicon_key=idChip];
salty [lexicon_key=salty];
idThrone1 -> yes [label="idThrone1_prop_idImmovable", edge_type=property, lexicon_key=idImmovable];
idThrone1 -> idiron [label="idThrone1_prop_idMaterial", edge_type=property, lexicon_key=idMaterial];
idThrone1 -> idChip2 [label=isEastOf, edge_type=relationship, lexicon_key=isEastOf];
idChip2 -> salty [label="idChip2_prop_idSaltiness", edge_type=property, lexicon_key=idSaltiness];
}
