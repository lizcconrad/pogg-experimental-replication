strict digraph {
idLexi [node_type="entity_node", root=root, lexicon_key=idLexi];
idMachine1 [lexicon_key=idMachine];
off [lexicon_key=off];
idOnSwitch1 [lexicon_key=idOnSwitch];
idDiamond1 [lexicon_key=idDiamond];
idLexi -> idMachine1 [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
idLexi -> idDiamond1 [label=isNear, edge_type=relationship, lexicon_key=isNear];
idMachine1 -> off [label="idMachine1_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
idMachine1 -> idOnSwitch1 [label="idMachine1_prop_idPowerControl", edge_type=property, lexicon_key=idPowerControl];
}
