strict digraph {
idFlashlight2 [node_type="entity_node", root=root, lexicon_key=idFlashlight];
idFlashlight2Switch [lexicon_key=idFlashlight2Switch];
on [lexicon_key=on];
orange [lexicon_key=orange];
idGreenRoomBackOpening [lexicon_key=idGreenRoomBackOpening];
medium [lexicon_key=medium];
idSafe2 [lexicon_key=idSafe];
idFlashlight2 -> idFlashlight2Switch [label="idFlashlight2_prop_idPowerControl", edge_type=property, lexicon_key=idPowerControl];
idFlashlight2 -> on [label="idFlashlight2_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
idFlashlight2 -> orange [label="idFlashlight2_prop_idColor", edge_type=property, lexicon_key=idColor];
idFlashlight2 -> idGreenRoomBackOpening [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
idFlashlight2 -> idSafe2 [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
idGreenRoomBackOpening -> medium [label="idGreenRoomBackOpening_prop_idHeight", edge_type=property, lexicon_key=idHeight];
}
