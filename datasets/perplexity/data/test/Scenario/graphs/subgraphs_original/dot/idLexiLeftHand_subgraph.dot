strict digraph {
idLexiLeftHand [node_type="entity_node", root=root, lexicon_key=idLexiLeftHand];
left [lexicon_key=left];
idGreenRoomBackOpeningDoor [lexicon_key=idGreenRoomBackOpeningDoor];
