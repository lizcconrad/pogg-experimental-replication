idGreenRoomBackOpeningDoor -> closed [label="idGreenRoomBackOpeningDoor_prop_idOpenState", edge_type=property, lexicon_key=idOpenState];
idGreenRoomBackOpeningDoor -> locked [label="idGreenRoomBackOpeningDoor_prop_idLockedState", edge_type=property, lexicon_key=idLockedState];
idGreenRoomBackOpeningDoor -> idLexiRightHand [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
}
