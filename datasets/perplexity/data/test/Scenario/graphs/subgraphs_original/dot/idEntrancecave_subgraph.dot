strict digraph {
idEntrancecave [node_type="entity_node", root=root, lexicon_key=idEntrancecave];
1 [lexicon_key=1];
open [lexicon_key=open];
idMachine1 [lexicon_key=idMachine];
off [lexicon_key=off];
idOnSwitch1 [lexicon_key=idOnSwitch];
idFlashlight2 [lexicon_key=idFlashlight];
idEntrancecave -> 1 [label="idEntrancecave_prop_idOrdinality", edge_type=property, lexicon_key=idOrdinality];
idEntrancecave -> open [label="idEntrancecave_prop_idOpenState", edge_type=property, lexicon_key=idOpenState];
idEntrancecave -> idMachine1 [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
idMachine1 -> off [label="idMachine1_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
idMachine1 -> idOnSwitch1 [label="idMachine1_prop_idPowerControl", edge_type=property, lexicon_key=idPowerControl];
idMachine1 -> idFlashlight2 [label=isNear, edge_type=relationship, lexicon_key=isNear];
}
