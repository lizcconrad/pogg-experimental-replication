strict digraph {
idPlage [node_type=entity, lexicon_key=idPlage];
2 [node_type=property, lexicon_key=2];
idFlashlight2 [node_type=entity, lexicon_key=idFlashlight];
lit [node_type=property, lexicon_key=lit];
