strict digraph {
idFlashlight1 [node_type=entity, lexicon_key=idFlashlight];
yellow [node_type=property, lexicon_key=yellow];
off [node_type=property, lexicon_key=off];
unlit [node_type=property, lexicon_key=unlit];
idLock2 [node_type=entity, lexicon_key=idLock];
locked [node_type=property, lexicon_key=locked];
idFlashlight1 -> yellow [label="idFlashlight1_prop_idColor", edge_type=property, lexicon_key=idColor];
idFlashlight1 -> off [label="idFlashlight1_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
idFlashlight1 -> unlit [label="idFlashlight1_prop_idLitState", edge_type=property, lexicon_key=idLitState];
idFlashlight1 -> idLock2 [label=isSouthOf, edge_type=relationship, lexicon_key=isSouthOf];
idLock2 -> locked [label="idLock2_prop_idLockedState", edge_type=property, lexicon_key=idLockedState];
}
