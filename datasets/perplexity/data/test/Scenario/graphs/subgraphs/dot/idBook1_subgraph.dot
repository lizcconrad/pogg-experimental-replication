strict digraph {
idBook1 [node_type=entity, lexicon_key=idBook];
open [node_type=property, lexicon_key=open];
idFlashlight1 [node_type=entity, lexicon_key=idFlashlight];
off [node_type=property, lexicon_key=off];
idBook1 -> open [label="idBook1_prop_idOpenState", edge_type=property, lexicon_key=idOpenState];
idBook1 -> idFlashlight1 [label=isNorthOf, edge_type=relationship, lexicon_key=isNorthOf];
idFlashlight1 -> off [label="idFlashlight1_prop_idPowerState", edge_type=property, lexicon_key=idPowerState];
}
