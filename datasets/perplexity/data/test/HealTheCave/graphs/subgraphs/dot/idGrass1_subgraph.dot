strict digraph {
idGrass1 [node_type=entity, lexicon_key=idGrass];
green [node_type=property, lexicon_key=green];
yes [node_type=property, lexicon_key=yes];
short [node_type=property, lexicon_key=short];
idMushroom1 [node_type=entity, lexicon_key=idMushroom];
blue [node_type=property, lexicon_key=blue];
idGrass1 -> green [label="idGrass1_prop_idColor", edge_type=property, lexicon_key=idColor];
idGrass1 -> yes [label="idGrass1_prop_idImmovable", edge_type=property, lexicon_key=idImmovable];
idGrass1 -> short [label="idGrass1_prop_idHeight", edge_type=property, lexicon_key=idHeight];
idGrass1 -> idMushroom1 [label=isWestOf, edge_type=relationship, lexicon_key=isWestOf];
idMushroom1 -> blue [label="idMushroom1_prop_idColor", edge_type=property, lexicon_key=idColor];
}
